<h1><%= @organisation.name %></h1>

<p>Hourly rate: <%= @organisation.hourly_rate %></p>

<ul>
  <li><%= link_to "Edit", edit_organisation_path(@organisation) %></li>
  <li><%= link_to "Destroy", organisation_path(@organisation), data: {
                    turbo_method: :delete,
                    turbo_confirm: "Are you sure?"
                  } %></li>
</ul>