<%= form_with model: @organisation do |form| %>
  <div>
    <%= form.label :name %><br>
    <%= form.text_field :name %>
    <% @organisation.errors.full_messages_for(:name).each do |message| %>
      <div><%= message %></div>
    <% end %>
  </div>

  <div>
    <%= form.label :hourly_rate %><br>
    <%= form.text_field :hourly_rate %>
    <% @organisation.errors.full_messages_for(:hourly_rate).each do |message| %>
      <div><%= message %></div>
    <% end %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>